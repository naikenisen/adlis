#!/usr/bin/env python3
import os

def count_files_in_subfolders(root_dir):
    counts = {}
    patients = {}
    for subdir, dirs, files in os.walk(root_dir):
        label = os.path.relpath(subdir, root_dir)
        if label == ".":
            continue
        image_files = [f for f in files if not f.startswith('.')]
        counts[label] = len(image_files)
        # Extraction des patients à partir du nom de fichier (ex: Image_20240529_...)
        patient_ids = set()
        for f in image_files:
            parts = f.split('_')
            if len(parts) > 1 and parts[1].isdigit() and len(parts[1]) == 8:
                patient_ids.add(parts[1])
        patients[label] = len(patient_ids)
    return counts, patients

def analyse_classification_dataset(path):
    print(f"Analyse du dataset de classification : {path}")
    counts, patients = count_files_in_subfolders(path)
    for label in counts:
        print(f"Classe '{label}': {counts[label]} fichiers, {patients[label]} patients")

def analyse_object_detection_dataset(path):
    print(f"Analyse du dataset de détection d'objets : {path}")
    for split in os.listdir(path):
        split_path = os.path.join(path, split)
        if os.path.isdir(split_path):
            counts, patients = count_files_in_subfolders(split_path)
            print(f"\nSplit '{split}':")
            for label in counts:
                print(f"  Classe '{label}': {counts[label]} fichiers, {patients[label]} patients")

if __name__ == "__main__":
    # Modifier les chemins selon votre structure de projet
    classification_path = "classification_dataset_v2"
    object_detection_path = "object_detection_dataset/dataset_split"

    if os.path.exists(classification_path):
        analyse_classification_dataset(classification_path)
    else:
        print(f"Le dossier {classification_path} n'existe pas.")

    if os.path.exists(object_detection_path):
        analyse_object_detection_dataset(object_detection_path)
    else:
        print(f"Le dossier {object_detection_path} n'existe pas.")